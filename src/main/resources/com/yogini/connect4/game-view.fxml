<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<GridPane fx:id="rootGridPane" style="-fx-background-color: #D9F7F0;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.yogini.connect4.Controller">
    <columnConstraints>
        <ColumnConstraints />
        <ColumnConstraints maxWidth="298.0" minWidth="225.0" prefWidth="225.0" />
    </columnConstraints>
    <rowConstraints>
        <RowConstraints minHeight="10.0" prefHeight="30.0" />
        <RowConstraints />
    </rowConstraints>
    <Pane GridPane.columnSpan="2" />
    <!-- Game Board Area -->
   <Pane fx:id="insertedDiscsPane" prefHeight="400.0" prefWidth="200.0" GridPane.rowIndex="1" />
    <!-- Right Side Panel -->
    <VBox style="-fx-background-color: #2B3B4C;" GridPane.columnIndex="1" GridPane.rowIndex="1">
        <TextField fx:id="playerOneTextField" prefHeight="27.0" prefWidth="199.0" promptText="Player One Name">
            <VBox.margin>
                <Insets left="15.0" right="15.0" top="35.0" />
            </VBox.margin>
        </TextField>
        <TextField fx:id="playerTwoTextField" promptText="Player Two Name">
            <VBox.margin>
                <Insets top="5.0" left="15.0" right="15.0"/>
            </VBox.margin>
        </TextField>
        <Button fx:id="setNamesButton" contentDisplay="CENTER" mnemonicParsing="false" prefHeight="27.0" prefWidth="194.0" text="Set Names">
            <VBox.margin>
                <Insets bottom="5.0" left="15.0" right="15.0" top="10.0" />
            </VBox.margin>
        </Button>
        <Label fx:id="playerNameLabel" alignment="CENTER" prefHeight="43.0" prefWidth="305.0" text="Player One" textFill="WHITE">
            <VBox.margin>
                <Insets top="70.0"/>
            </VBox.margin>
            <padding>
                <Insets bottom="10.0"/>
            </padding>
           <font>
               <Font name="System Bold" size="29.0" />
           </font>
        </Label>
        <Label alignment="CENTER" prefHeight="32.0" prefWidth="216.0" text="Turn" textFill="WHITE">
           <font>
               <Font size="26.0" />
           </font>
        </Label>
        <Region prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS" />
    </VBox>
</GridPane>
